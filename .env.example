# Server Configuration
PORT=6000
NODE_ENV=development

# Application Branding
APP_NAME=ResiSmart
SUPPORT_EMAIL=support@resismart.com

# Database Configuration
MONGO_URI=mongodb://127.0.0.1:27017/resismart

# Security Configurations
# Generate strong secrets in production using: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_ACCESS_SECRET=your_jwt_access_secret_key_change_me_in_production
JWT_REFRESH_SECRET=your_jwt_refresh_secret_key_change_me_in_production

# JWT Expiry Times
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# SMTP Configuration
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=2525
SMTP_USER=your_smtp_username
SMTP_PASSWORD=your_smtp_password
SMTP_FROM_NAME="SaaS Platform"
SMTP_FROM_EMAIL=your_sender_email
SMTP_REPLY_TO=your_reply_to_email

# Initial Owner Credentials for Seeding
INITIAL_OWNER_EMAIL=admin@resismart.com
INITIAL_OWNER_PASSWORD=Admin@123

# Frontend URL (used in emails: reset links, credentials, invoices)
FRONTEND_URL=http://localhost:4444

# CORS (comma-separated allowed origins)
CORS_ORIGINS=http://localhost:4444,http://localhost:3000

# AWS S3 Configuration
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_REGION=eu-north-1
AWS_S3_BUCKET=your_s3_bucket_name

# Razorpay (live payment gateway)
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret
